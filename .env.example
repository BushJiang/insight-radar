# PostgreSQL 数据库连接
DATABASE_URL=postgres://user:password@localhost:5432/insightradar

# Milvus / Zilliz 向量数据库
MILVUS_ADDRESS=localhost:19530
MILVUS_TOKEN=
MILVUS_PROJECT_PROFILE_COLLECTION=InsightRadar
MILVUS_IVF_NLIST=128
MILVUS_IVF_NPROBE=16

# SiliconFlow embedding 服务
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 项目简介向量配置
PROJECT_PROFILE_EMBEDDING_MODEL=BAAI/bge-m3
PROJECT_PROFILE_EMBEDDING_VERSION=siliconflow-bge-m3-1024-v1
